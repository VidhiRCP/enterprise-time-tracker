# Database / Next
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
NEXTAUTH_URL=http://localhost:3000

# Note: keep the SUPABASE_SERVICE_ROLE_KEY and OPENAI_API_KEY secret. Do not commit real keys.
