generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TimerSessionStatus {
  RUNNING
  PAUSED
  FINALIZED
  ABANDONED
}

enum TimeEntrySource {
  TIMER
  MANUAL
  RECOVERED
}

enum TimeEntryStatus {
  SAVED
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  displayName    String
  entraObjectId  String?
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  assignments    ProjectAssignment[]
  timerSessions  TimerSession[]
  timeEntries    TimeEntry[]
  calendarAllocations CalendarAllocation[]
}

model Project {
  id             String              @id @default(cuid())
  projectId      String              @unique
  projectName    String
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  assignments    ProjectAssignment[]
  timerSessions  TimerSession[]
  timeEntries    TimeEntry[]
  calendarAllocations CalendarAllocation[]
}

model ProjectAssignment {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  active      Boolean  @default(true)
  assignedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  @@unique([userId, projectId])
}

model TimerSession {
  id                 String             @id @default(cuid())
  userId             String
  projectId          String
  status             TimerSessionStatus
  startedAt          DateTime
  lastResumedAt      DateTime?
  pausedAt           DateTime?
  stoppedAt          DateTime?
  finalizedAt        DateTime?
  accumulatedSeconds Int                @default(0)
  notesDraft         String?
  lastHeartbeatAt    DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project            @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  timeEntries        TimeEntry[]
}

model TimeEntry {
  id              String          @id @default(cuid())
  userId          String
  projectId       String
  timerSessionId  String?
  workDate        DateTime
  durationMinutes Int
  notes           String?
  source          TimeEntrySource
  status          TimeEntryStatus
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project         @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  timerSession    TimerSession?   @relation(fields: [timerSessionId], references: [id], onDelete: SetNull)
}

model CalendarAllocation {
  id            String   @id @default(cuid())
  userId        String
  projectId     String
  eventId       String
  eventSubject  String
  eventStart    DateTime
  eventEnd      DateTime
  durationMin   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project  @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  @@unique([userId, eventId])
}
